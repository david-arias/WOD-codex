# ============================================================
# El Códice del Narrador — Variables de Entorno (Plantilla)
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-secret-key>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# --- Base de Datos (PostgreSQL via Supabase) ---
# Formato asyncpg para SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://<user>:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- Seguridad ---
SECRET_KEY=<generate-with: openssl rand -hex 32>

# --- IA — Elige al menos una opción ---
# Opción A: Groq (LLaMA 3, Mixtral) — Free tier disponible
GROQ_API_KEY=<groq-api-key>

# Opción B: Google Gemini — Free tier generoso
GEMINI_API_KEY=<gemini-api-key>

# Opción C: Ollama (local, sin API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Embeddings ---
# Modelo HuggingFace para ChromaDB (se descarga automáticamente)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Entorno ---
ENVIRONMENT=development   # development | staging | production

# --- CORS ---
FRONTEND_URL=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
